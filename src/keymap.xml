<keymap>
	<!-- keymap.xml
		m = make -> Normal 
		key press b = break -> Key released l = long -> Long key press r = repeat 
		-> Key locked (pressed continuously) "m" arrives once, as soon as the key 
		is pressed "b" arrives as soon as the key is released. "l" arrives after 
		5 repeats, but then only once (repeat still arrives) "r" arrives after "m", 
		when the key is pressed continuously until the key is released Flags can 
		be combined, eg. flags="mr" -->
	<map context="MDCActions">
		<key id="KEY_OK" mapto="ok" flags="m"/>
		<key id="KEY_ENTER" mapto="ok" flags="m"/>
		<key id="KEY_EXIT" mapto="exit" flags="m"/>
		<key id="KEY_LEFT" mapto="left" flags="mr"/>
		<key id="KEY_RIGHT" mapto="right" flags="mr"/>
		<key id="KEY_UP" mapto="up" flags="mr"/>
		<key id="KEY_DOWN" mapto="down" flags="mr"/>
		<key id="KEY_RED" mapto="red" flags="mr"/>
		<key id="KEY_GREEN" mapto="green" flags="mr"/>
		<key id="KEY_BLUE" mapto="blue" flags="mr"/>
		<key id="KEY_YELLOW" mapto="yellow" flags="mr"/>
		<key id="KEY_MUTE" mapto="mute" flags="m"/>
		<key id="KEY_MENU" mapto="menu" flags="mr"/>
		<key id="KEY_INFO" mapto="info" flags="m"/>
		<key id="KEY_TV" mapto="stop" flags="m"/>
		<key id="KEY_1" mapto="1" flags="mr"/>
		<key id="KEY_2" mapto="2" flags="mr"/>
		<key id="KEY_3" mapto="3" flags="mr"/>
		<key id="KEY_4" mapto="4" flags="mr"/>
		<key id="KEY_5" mapto="5" flags="mr"/>
		<key id="KEY_6" mapto="6" flags="mr"/>
		<key id="KEY_7" mapto="7" flags="mr"/>
		<key id="KEY_8" mapto="8" flags="mr"/>
		<key id="KEY_9" mapto="9" flags="mr"/>
		<key id="KEY_0" mapto="0" flags="mr"/>
		<key id="KEY_CHANNELUP" mapto="nextBouquet" flags="mr"/>
		<key id="KEY_PAGEUP" mapto="nextBouquet" flags="mr"/>
		<key id="KEY_CHANNELDOWN" mapto="prevBouquet" flags="mr"/>
		<key id="KEY_PAGEDOWN" mapto="prevBouquet" flags="mr"/>
		<key id="KEY_PREVIOUS" mapto="keyPrev" flags="mr"/>
		<key id="KEY_NEXT" mapto="keyNext" flags="mr"/>
		<key id="KEY_TEXT" mapto="keyText" flags="m" />
		<key id="KEY_STOP" mapto="stop" flags="m"/>
		<key id="KEY_PLAY" mapto="playpause" flags="m"/>
		<key id="KEY_PLAYPAUSE" mapto="playpause" flags="m"/>
		<key id="KEY_PAUSE" mapto="playpause" flags="m"/>
		<key id="KEY_REWIND" mapto="seekBack" flags="m"/>
		<key id="KEY_FASTFORWARD" mapto="seekFwd" flags="m"/>
		<key id="KEY_POWER" mapto="exit" flags="m"/>
		<key id="KEY_HELP" mapto="help" flags="m"/>
	</map>
	<map context="MDCPlayerActions">
		<key id="KEY_POWER" mapto="MDCEXIT" flags="m" />
		<key id="KEY_TV" mapto="MDCEXIT" flags="m" />
		<key id="KEY_STOP" mapto="MDCEXIT" flags="m" />
		<key id="KEY_EXIT" mapto="MDCEXIT" flags="m" />
		<key id="KEY_HOME" mapto="MDCEXIT" flags="m" />
		<key id="KEY_ESC" mapto="MDCEXIT" flags="m" />
	</map>
</keymap>
