	<layout name="MDCDate">
		<widget font="Regular;34" halign="right" position="1240,5" render="Label" size="400,70" source="global.CurrentTime" valign="center">
			<convert type="ClockToText">Date</convert>
		</widget>
	</layout>
	<layout name="MDCTime">
		<widget font="Regular;34" halign="right" position="1650,5" render="Label" size="120,70" source="global.CurrentTime" valign="center">
			<convert type="ClockToText">Default</convert>
		</widget>
	</layout>
